{
  "expo": {
    "name": "GescoPay",
    "slug": "gescopay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gescopay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A2342"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gescopay.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to authenticate securely",
        "NSCameraUsageDescription": "Used to scan QR codes for payments"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A2342"
      },
      "package": "com.gescopay.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow GescoPay to use Face ID to authenticate you."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GescoPay to access your camera for QR scanning."
        }
      ],
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
