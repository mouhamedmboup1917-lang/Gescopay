# GescoPay Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=3001
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://gescopay:password@localhost:5432/gescopay_dev?schema=public"

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis (for caching, OTP, rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Frontend URL (for CORS)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000

# AWS S3 (for file uploads)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=gescopay-uploads

# Email (Nodemailer / SendGrid / SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=noreply@gescopay.com
FROM_NAME=GescoPay

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+your-twilio-number

# Wave API
WAVE_API_KEY=
WAVE_API_SECRET=
WAVE_BASE_URL=https://api.wave.com/v1

# Orange Money API
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_BASE_URL=https://api.orange.com/orange-money-webpay

# MTN MoMo API
MTN_MOMO_USER_ID=
MTN_MOMO_API_KEY=
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com

# Virtual Card Provider
CARD_PROVIDER_API_KEY=
CARD_PROVIDER_BASE_URL=

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key-here!

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# App Settings
MAX_WALLETS_PER_USER=10
MAX_CARDS_PER_USER=3
TRANSACTION_FEE_RATE=0.01
MIN_TRANSACTION_AMOUNT=100
MAX_TRANSACTION_AMOUNT=5000000
SETTLEMENT_FEE_RATE=0.01
OTP_EXPIRES_IN_MINUTES=5
OTP_MAX_ATTEMPTS=3
